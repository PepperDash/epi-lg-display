{
    "[csharp]": {
        "editor.defaultFormatter": "ms-dotnettools.csharp",
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file"
    },
    "csharp.inlayHints.enableInlayHintsForImplicitObjectCreation": true,
    "csharp.inlayHints.enableInlayHintsForImplicitVariableTypes": true,
    "csharp.inlayHints.enableInlayHintsForLambdaParameterTypes": true,
    "csharp.inlayHints.enableInlayHintsForTypes": true,
    "dotnet.formatting.organizeImportsOnFormat": true,
    "breadcrumbs.symbolSortOrder": "type",
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#63a1c9",
        "activityBar.background": "#63a1c9",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#a6397b",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#63a1c9",
        "statusBar.background": "#408aba",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#63a1c9",
        "statusBarItem.remoteBackground": "#408aba",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#408aba",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#408aba99",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#408aba"
}